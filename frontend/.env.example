# Supabase (for Auth). Copy to .env and fill in.
# Get URL and anon key from Supabase Dashboard → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional: auto sign-in as admin when no session (no login screen)
# REACT_APP_AUTO_LOGIN_EMAIL=admin@gmail.com
# REACT_APP_AUTO_LOGIN_PASSWORD=your-admin-password
